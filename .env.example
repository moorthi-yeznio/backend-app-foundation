# App
NODE_ENV=development
PORT=3000
API_PREFIX=api
API_VERSION=v1

# Database — use Supabase transaction pooler URL for DATABASE_URL
# and session pooler or direct connection for DIRECT_URL
DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/DATABASE?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# JWT — generate with: openssl rand -hex 64
JWT_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=7d

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# Logging — fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# Rate Limiting — TTL in milliseconds, limit = max requests per TTL window
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
